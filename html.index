<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>Fun-Facts.web — For all of you</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
/* GLOBAL */
:root {
    --fun-gradient: linear-gradient(120deg,
        #ff9a9e,
        #fad0c4,
        #fbc2eb,
        #a18cd1
    );
}

body {
    margin: 0;
    font-family: 'Inter', sans-serif;
    background: var(--fun-gradient);
    background-size: 400% 400%;
    animation: gradientFlow 25s ease infinite;
    color: black;
    overflow: hidden;
}

@keyframes gradientFlow {
    0% {background-position: 0% 50%;}
    50% {background-position: 100% 50%;}
    100% {background-position: 0% 50%;}
}

/* HEADER */
header {
    position: fixed;
    top: 0;
    left: 60px;
    height: 60px;
    width: calc(100% - 60px);
    display: flex;
    align-items: center;
    padding-left: 20px;
    font-size: 22px;
    font-weight: 700;
    color: black;
    z-index: 1000;
}

/* SIDEBAR */
.sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 60px;
    height: 100vh;
    padding-top: 70px;
    display: flex;
    flex-direction: column;
    gap: 15px;
    align-items: center;
    background: rgba(255,255,255,0.2);
    z-index: 1001;
}

.sidebar .emoji {
    font-size: 28px;
    cursor: pointer;
}

/* PANEL */
#panel {
    position: fixed;
    left: 60px;
    bottom: -100%;
    width: calc(100% - 60px);
    height: calc(100% - 60px);

    background: var(--fun-gradient);
    background-size: 400% 400%;
    animation: gradientFlow 25s ease infinite;

    border-radius: 20px 20px 0 0;
    padding: 20px;
    overflow-y: auto;
    transition: bottom 0.5s ease, opacity 0.3s ease;

    opacity: 0;
    pointer-events: none;

    color: black;
    z-index: 999;
}

#panel.open {
    bottom: 0;
    opacity: 1;
    pointer-events: auto;
}

.panel-title {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 25px;
}

.fact {
    background: rgba(255,255,255,0.4);
    padding: 15px;
    border-radius: 12px;
    margin-bottom: 15px;
    font-size: 18px;
}
</style>
</head>

<body>

<header>✨ Fun-Facts.web — For all of you ✨</header>

<div class="sidebar">
    <div class="emoji" data-cat="tiere">🐾</div>
    <div class="emoji" data-cat="random">✨</div>
    <div class="emoji" data-cat="tag">⭐</div>
</div>

<div id="panel">
    <div id="panel-title" class="panel-title"></div>
    <div id="panel-content"></div>
</div>

<script>
const panel = document.getElementById("panel");
const title = document.getElementById("panel-title");
const content = document.getElementById("panel-content");

document.querySelectorAll(".emoji").forEach(e => {
    e.addEventListener("click", () => openPanel(e.dataset.cat));
});

function openPanel(cat) {
    panel.classList.add("open");

    if (cat === "tiere") {
        title.textContent = "🐾 Tiere";
        content.innerHTML = `<div class="fact">Katzen schlafen 70% ihres Lebens.</div>`;
    }

    if (cat === "random") {
        title.textContent = "✨ Random";
        content.innerHTML = `<div class="fact">Honig verdirbt nie.</div>`;
    }

    if (cat === "tag") {
        title.textContent = "⭐ Fakt des Tages";
        content.innerHTML = `<div class="fact">Bananen sind Beeren.</div>`;
    }
}
</script>

</body>
</html>
